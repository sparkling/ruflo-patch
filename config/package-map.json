{
  "description": "Package name mappings from upstream to ruflo (ADR-0006, scoped to @sparkleideas)",
  "scopePrefix": {
    "from": "@claude-flow/",
    "to": "@sparkleideas/"
  },
  "scoped": {
    "@claude-flow/cli": "@sparkleideas/cli",
    "@claude-flow/memory": "@sparkleideas/memory",
    "@claude-flow/hooks": "@sparkleideas/hooks",
    "@claude-flow/neural": "@sparkleideas/neural",
    "@claude-flow/shared": "@sparkleideas/shared",
    "@claude-flow/embeddings": "@sparkleideas/embeddings",
    "@claude-flow/codex": "@sparkleideas/codex",
    "@claude-flow/aidefence": "@sparkleideas/aidefence",
    "@claude-flow/browser": "@sparkleideas/browser",
    "@claude-flow/plugins": "@sparkleideas/plugins",
    "@claude-flow/providers": "@sparkleideas/providers",
    "@claude-flow/claims": "@sparkleideas/claims",
    "@claude-flow/guidance": "@sparkleideas/guidance",
    "@claude-flow/mcp": "@sparkleideas/mcp",
    "@claude-flow/integration": "@sparkleideas/integration",
    "@claude-flow/deployment": "@sparkleideas/deployment",
    "@claude-flow/swarm": "@sparkleideas/swarm",
    "@claude-flow/security": "@sparkleideas/security",
    "@claude-flow/performance": "@sparkleideas/performance",
    "@claude-flow/testing": "@sparkleideas/testing"
  },
  "unscoped": {
    "claude-flow": "@sparkleideas/claude-flow",
    "ruflo": "@sparkleideas/ruflo",
    "agentdb": "@sparkleideas/agentdb",
    "agentic-flow": "@sparkleideas/agentic-flow",
    "ruv-swarm": "@sparkleideas/ruv-swarm"
  },
  "ruvectorScope": {
    "from": "@ruvector/",
    "to": "@sparkleideas/ruvector-"
  },
  "ruvectorUnscoped": {
    "ruvector": "@sparkleideas/ruvector",
    "ruvector-core-darwin-arm64": "@sparkleideas/ruvector-core-darwin-arm64",
    "ruvector-core-darwin-x64": "@sparkleideas/ruvector-core-darwin-x64",
    "ruvector-core-linux-x64-gnu": "@sparkleideas/ruvector-core-linux-x64-gnu",
    "ruvector-core-linux-arm64-gnu": "@sparkleideas/ruvector-core-linux-arm64-gnu",
    "ruvector-core-win32-x64-msvc": "@sparkleideas/ruvector-core-win32-x64-msvc"
  },
  "upstreamRepos": {
    "ruvnet/ruflo": {
      "packages": [
        "ruflo",
        "claude-flow",
        "@claude-flow/cli",
        "@claude-flow/memory",
        "@claude-flow/hooks",
        "@claude-flow/neural",
        "@claude-flow/shared",
        "@claude-flow/embeddings",
        "@claude-flow/codex",
        "@claude-flow/aidefence",
        "@claude-flow/browser",
        "@claude-flow/plugins",
        "@claude-flow/providers",
        "@claude-flow/claims",
        "@claude-flow/guidance",
        "@claude-flow/mcp",
        "@claude-flow/integration",
        "@claude-flow/deployment",
        "@claude-flow/swarm",
        "@claude-flow/security",
        "@claude-flow/performance",
        "@claude-flow/testing"
      ],
      "clonePath": "/home/claude/src/upstream/ruflo"
    },
    "ruvnet/agentic-flow": {
      "packages": ["agentdb", "agentic-flow"],
      "clonePath": "/home/claude/src/upstream/agentic-flow"
    },
    "ruvnet/ruv-FANN": {
      "packages": ["ruv-swarm"],
      "clonePath": "/home/claude/src/upstream/ruv-FANN"
    }
  }
}
