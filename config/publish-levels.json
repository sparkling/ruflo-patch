{
  "description": "Topological publish order (ADR-0014). Packages within a level have no mutual dependencies.",
  "levels": [
    {
      "level": 1,
      "description": "Depends only on @ruvector/* (public npm)",
      "packages": [
        "@sparkleideas/agentdb",
        "@sparkleideas/agentic-flow",
        "@sparkleideas/ruv-swarm"
      ]
    },
    {
      "level": 2,
      "description": "Depends on Level 1",
      "packages": [
        "@sparkleideas/shared",
        "@sparkleideas/memory",
        "@sparkleideas/embeddings",
        "@sparkleideas/codex",
        "@sparkleideas/aidefence"
      ]
    },
    {
      "level": 3,
      "description": "Depends on Level 2",
      "packages": [
        "@sparkleideas/neural",
        "@sparkleideas/hooks",
        "@sparkleideas/browser",
        "@sparkleideas/plugins",
        "@sparkleideas/providers",
        "@sparkleideas/claims"
      ]
    },
    {
      "level": 4,
      "description": "Depends on Level 3",
      "packages": [
        "@sparkleideas/guidance",
        "@sparkleideas/mcp",
        "@sparkleideas/integration",
        "@sparkleideas/deployment",
        "@sparkleideas/swarm",
        "@sparkleideas/security",
        "@sparkleideas/performance",
        "@sparkleideas/testing"
      ]
    },
    {
      "level": 5,
      "description": "Root packages",
      "packages": [
        "@sparkleideas/cli",
        "@sparkleideas/claude-flow",
        "@sparkleideas/ruflo-patch"
      ]
    }
  ],
  "rateLimitMs": 2000
}
