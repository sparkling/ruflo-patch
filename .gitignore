# Runtime state
scripts/.last-build-state
config/.publish-timing.json
.claude/projects/
.claude/worktrees/
.entire/
.codex/
CLAUDE.local.md

# Claude Flow runtime (keep config, ignore bulk)
.claude-flow/data/graph-state.json
.claude-flow/logs/
.claude-flow/sessions/
.claude-flow/neural/
.claude-flow/daemon.pid
.claude-flow/**/*.log
.claude-flow/**/*.tmp

# Environment variables
.env
.env.local
.env.*.local

# Node
node_modules/
/package-lock.json

# Swarm runtime databases
.swarm/

# npm packaging artifacts
npm/dist/
package/
*.tgz
**/vendor/*.tgz
**/vendor/*.sha256

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ruvector runtime state
.ruvector/

# Helper backups
.claude/helpers.backup.*/

# Test output logs
logs/
verdaccio.log

# OS
.DS_Store
Thumbs.db

# Test results (ADR-0020)
test-results/
# SQLite catalog index (ADR-0094 Sprint 2 / ADR-0096) — explicit entries for
# when only specific test-results/ artefacts are tracked:
test-results/catalog.db
test-results/catalog.db-*

# RVF :memory: literal filename (safety net — fork rvf-backend.ts has
# :memory: guards at every file-writing site, but a direct call bypassing
# the backend wrapper could leave this artifact; see phase8-followups-plan.md
# ITEM 2).
:memory:

# Scheduled tasks runtime lock
.claude/scheduled_tasks.lock

# Stray .claude-flow/ runtime dirs created by tools that anchored on cwd
# instead of project root (ADR-0100 / ADR-0118 known-debt). Match the dir
# anywhere it appears EXCEPT the project root, which is the intentional
# runtime location (specific subpaths under root .claude-flow/ are governed
# by the rules earlier in this file).
**/.claude-flow/
!/.claude-flow/
