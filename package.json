{
  "name": "@sparkleideas/ruflo",
  "version": "3.1.0-alpha.14-patch.15",
  "description": "Drop-in replacement for ruflo/@claude-flow/cli — rebuilt from source with bug fixes and current upstream commits",
  "scripts": {
    "release": "bash scripts/ruflo-publish.sh"
  },
  "config": {
    "packageMap": "config/package-map.json",
    "publishLevels": "config/publish-levels.json"
  },
  "private": false,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ruflo": "bin/ruflo.mjs"
  },
  "files": [
    "bin",
    "lib",
    "scripts",
    "config"
  ],
  "keywords": [
    "ruflo",
    "@claude-flow/cli",
    "patch",
    "hotfix",
    "ruvector",
    "ruv-swarm"
  ],
  "packageManager": "npm@10",
  "devDependencies": {
    "verdaccio": "^6.2.9"
  }
}
